{
  "name": "@openclaw/web",
  "version": "0.0.1",
  "description": "OpenClaw Web - React Mobile UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "build:android": "pnpm build && pnpm cap:sync",
    "build:ios": "pnpm build && pnpm cap:sync"
  },
  "dependencies": {
    "@ant-design/x": "^2.3.0",
    "@openclaw/web-application": "workspace:*",
    "@openclaw/web-domain": "workspace:*",
    "@openclaw/web-infrastructure": "workspace:*",
    "antd-mobile": "^5.42.3",
    "antd-mobile-icons": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
