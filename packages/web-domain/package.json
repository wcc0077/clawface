{
  "name": "@openclaw/web-domain",
  "version": "0.0.1",
  "description": "OpenClaw Web Domain Layer - Core business entities and interfaces",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./entities": "./src/entities/index.ts",
    "./repositories": "./src/repositories/index.ts",
    "./services": "./src/services/index.ts",
    "./events": "./src/events/index.ts",
